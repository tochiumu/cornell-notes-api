generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id        String   @id @default(uuid())
  email     String   @unique
  password  String
  name      String?
  notes     Note[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Note {
  id        String    @id @default(uuid())
  userId    String?
  title     String
  cue       String?
  note      String
  summary   String?
  color     String    @default("#FDF8F0")
  tagsData  Json?
  drawings  Json?
  user      User?     @relation(fields: [userId], references: [id], onDelete: Cascade)
  cues      Cue[]
  tags      NoteTag[]
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  @@index([userId])
}

model Cue {
  id       String @id @default(uuid())
  noteId   String
  question String
  answer   String?

  note Note @relation(fields: [noteId], references: [id], onDelete: Cascade)
}

model Tag {
  id    String    @id @default(uuid())
  name  String    @unique
  color String    @default("#6B7280")
  notes NoteTag[]
}

model NoteTag {
  noteId String
  tagId  String
  note   Note @relation(fields: [noteId], references: [id], onDelete: Cascade)
  tag    Tag  @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([noteId, tagId])
}